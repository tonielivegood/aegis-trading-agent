# ============================================================
#  Aegis — BNB Hack 2026 Track 1 Trading Agent — TEMPLATE
#  Copy to .env and fill in real values LOCALLY. Never paste secrets into chat.
#  .env is gitignored; this template holds placeholders only.
# ============================================================

# --- Wallet (LOCAL ONLY — never share) ---
AGENT_PRIVATE_KEY=your_private_key_here
AGENT_WALLET_ADDRESS=your_wallet_address_here

# --- BSC Network ---
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_CHAIN_ID=56

# --- Hackathon Registration Contract ---
HACKATHON_CONTRACT=0x212c61b9b72c95d95bf29cf032f5e5635629aed5

# --- PancakeSwap V2 Router (BSC mainnet) ---
PANCAKE_ROUTER=0x10ED43C718714eb63d5aA57B78B54704E256024E
WBNB_ADDRESS=0xbb4CdB9CBd36B01bD1cBaEBF2De08d9173bc095c
USDT_ADDRESS=0x55d398326f99059fF775485246999027B3197955

# --- BscScan API ---
BSCSCAN_API_KEY=your_bscscan_api_key

# --- CoinMarketCap Pro API (signals + historical validation) ---
CMC_API_KEY=
CMC_API_BASE=https://pro-api.coinmarketcap.com

# --- Anthropic (Claude) API — signal layer only ---
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Telegram alerts (optional; leave blank to disable) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Execution backend: "pancake" (default, registered wallet) or "twak" ---
#  Leave as pancake for the contest run. Set to twak ONLY when demoing the
#  Trust Wallet Agent Kit path (requires the two TWAK creds below).
EXECUTION_BACKEND=pancake
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=

# ============================================================
#  Binance Wallet Web3 API — quote / route / unsigned-tx readiness.
#  Aegis uses this as a native on-chain agent layer. It NEVER signs or
#  broadcasts: signing stays local/self-custody (Trust Wallet Agent Kit /
#  PancakeSwap). All flags default OFF except MEV protection.
# ============================================================
BINANCE_WEB3_ENABLED=false
BINANCE_WEB3_API_KEY=
BINANCE_WEB3_API_SECRET=
BINANCE_WEB3_BASE_URL=
BINANCE_WEB3_QUOTE_ENABLED=false
BINANCE_WEB3_EXECUTION_ENABLED=false
BINANCE_WEB3_BROADCAST_ENABLED=false
BINANCE_WEB3_MEV_PROTECTION_ENABLED=true

# --- Binance Alpha live market data (5m volume confirmation) ---
#  Independent of the Web3 execution flags above — market data only.
BINANCE_ALPHA_MARKET_DATA_ENABLED=true
BINANCE_ALPHA_KLINES_INTERVAL=5m
BINANCE_ALPHA_FRESHNESS_SECONDS=600

# --- Catalyst / news sources ---
X_BEARER_TOKEN=
CATALYST_CMC_ENABLED=false
CATALYST_X_ENABLED=false

# ============================================================
#  Strategy + risk (event-driven alpha radar; DRY_RUN by default)
# ============================================================
DRY_RUN=true
STRATEGY_MODE=event_alpha
EVENT_RADAR_ENABLED=true
EVENT_SIGNAL_THRESHOLD=70
MAX_OPEN_POSITIONS=3
DEFAULT_ORDER_USD=10
MAX_POSITION_USD=10
STABLECOIN_FLOOR_USD=6
STABLECOIN_FLOOR_PCT=0.15
MAX_HOLD_MINUTES=300
VOLUME_EXIT_MULTIPLE=5
HARD_TAKE_PROFIT_MULTIPLE=2.0

# --- Baseline risk parameters ---
TOTAL_BUDGET_USD=100
MAX_DRAWDOWN_ALERT=0.20
MAX_DRAWDOWN_CAP=0.30
MAX_POSITION_PCT=0.10
MIN_TRADE_INTERVAL_H=4
TARGET_DAILY_TRADES=4
SLIPPAGE_BPS=50
MIN_PORTFOLIO_VALUE_USD=1.50
STRATEGY_TICK_MIN=15
