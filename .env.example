# ============================================================
#  BNB Hack 2026 — Track 1 Trading Agent — TEMPLATE
#  Copy to .env and fill in real values. Do NOT put secrets here.
# ============================================================

# --- Wallet ---
AGENT_PRIVATE_KEY=your_private_key_here
AGENT_WALLET_ADDRESS=your_wallet_address_here

# --- BSC Network ---
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_CHAIN_ID=56

# --- Hackathon Registration Contract ---
HACKATHON_CONTRACT=0x212c61b9b72c95d95bf29cf032f5e5635629aed5

# --- PancakeSwap V2 Router (BSC mainnet) ---
PANCAKE_ROUTER=0x10ED43C718714eb63d5aA57B78B54704E256024E
WBNB_ADDRESS=0xbb4CdB9CBd36B01bD1cBaEBF2De08d9173bc095c
USDT_ADDRESS=0x55d398326f99059fF775485246999027B3197955

# --- BscScan API ---
BSCSCAN_API_KEY=your_bscscan_api_key

# --- CoinMarketCap Data API ---
CMC_API_KEY=your_cmc_api_key
CMC_API_BASE=https://pro-api.coinmarketcap.com

# --- Anthropic (Claude) API — Signal layer ONLY ---
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Telegram alerts (optional; leave blank to disable) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Risk Parameters ---
TOTAL_BUDGET_USD=100
MAX_DRAWDOWN_ALERT=0.20
MAX_DRAWDOWN_CAP=0.30
MAX_POSITION_PCT=0.10
STABLECOIN_FLOOR_PCT=0.20
MIN_TRADE_INTERVAL_H=4
TARGET_DAILY_TRADES=4
SLIPPAGE_BPS=50
MIN_PORTFOLIO_VALUE_USD=1.50
STRATEGY_TICK_MIN=15

# --- Mode ---
DRY_RUN=true
